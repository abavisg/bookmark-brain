{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["chrome"]
  },
  "include": ["src/popup/**/*", "src/dashboard/**/*", "src/content/**/*", "src/shared/**/*", "src/lib/**/*", "src/components/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test/**/*"]
}
